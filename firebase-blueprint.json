{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ExaminationHistory": {
      "title": "Examination History",
      "description": "History of symptoms analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "isi_keluhan": { "type": "string" },
        "jawaban_ai": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "isi_keluhan", "jawaban_ai", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles collection"
    },
    "history_pemeriksaan/{historyId}": {
      "schema": "ExaminationHistory",
      "description": "Symptom analysis history collection"
    }
  }
}
